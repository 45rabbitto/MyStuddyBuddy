<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abu_muda">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progress Belajar 📊"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="16dp"/>

        <!-- CARD TOTAL PROGRESS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="Total Progress"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/dark_text"/>

                <TextView
                    android:id="@+id/tvTotalPercent"
                    android:text="70%"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/primary"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/progressBarTotal"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:progress="70"
                    android:max="100"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DETAIL PROGRESS -->
        <TextView
            android:text="Detail Aktivitas"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins"
            android:textColor="@color/dark_text"
            android:layout_marginBottom="12dp"/>

        <!-- Upload -->
        <include layout="@layout/item_progress_row"
            android:id="@+id/progressUpload"/>

        <!-- Ringkasan -->
        <include layout="@layout/item_progress_row"
            android:id="@+id/progressSummary"/>

        <!-- Quiz -->
        <include layout="@layout/item_progress_row"
            android:id="@+id/progressQuiz"/>

        <!-- Chatbot -->
        <include layout="@layout/item_progress_row"
            android:id="@+id/progressChatbot"/>

    </LinearLayout>
</ScrollView>