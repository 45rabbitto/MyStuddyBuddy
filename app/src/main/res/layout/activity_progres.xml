<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abu_muda">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER NAVIGATION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- Tombol Back -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="10dp"
                android:src="@drawable/back"
                android:tint="@color/dark_text" />

            <!-- Judul -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Progress Belajar"
                android:gravity="center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:textColor="@color/dark_text"/>
        </LinearLayout>

        <!-- CARD RINGKASAN -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ringkasan Progress"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/dark_text"
                    android:fontFamily="@font/poppins"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <!-- Materi -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textStyle="bold"
                            android:textSize="24sp"
                            android:textColor="@color/sky_blue"
                            android:fontFamily="@font/poppins"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Materi"
                            android:textSize="12sp"
                            android:textColor="@color/dark_text"/>
                    </LinearLayout>

                    <!-- Kuis -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="28"
                            android:textStyle="bold"
                            android:textSize="24sp"
                            android:textColor="@color/sky_blue"
                            android:fontFamily="@font/poppins"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kuis"
                            android:textSize="12sp"
                            android:textColor="@color/dark_text"/>
                    </LinearLayout>

                    <!-- Skor -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="76%"
                            android:textStyle="bold"
                            android:textSize="24sp"
                            android:textColor="@color/sky_blue"
                            android:fontFamily="@font/poppins"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rata-rata Skor"
                            android:textSize="12sp"
                            android:textColor="@color/dark_text"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- MATERI SELESAI -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Materi Selesai"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/dark_text"
            android:fontFamily="@font/poppins"
            android:layout_marginBottom="12dp"/>

        <!-- CARD PROGRESS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Algoritma -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Algoritma Dasar"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"/>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="@color/sky_blue"
                    android:progressBackgroundTint="@color/abu_muda"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="12sp"
                    android:textColor="@color/dark_text"
                    android:layout_gravity="end"
                    android:layout_marginBottom="14dp"/>

                <!-- Struktur Data -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Struktur Data"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"/>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="75"
                    android:progressTint="@color/sky_blue"
                    android:progressBackgroundTint="@color/abu_muda"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75%"
                    android:textSize="12sp"
                    android:textColor="@color/dark_text"
                    android:layout_gravity="end"
                    android:layout_marginBottom="14dp"/>

                <!-- Basis Data -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Basis Data"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"/>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="40"
                    android:progressTint="@color/sky_blue"
                    android:progressBackgroundTint="@color/abu_muda"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="40%"
                    android:textSize="12sp"
                    android:textColor="@color/dark_text"
                    android:layout_gravity="end"/>

                <!-- Tombol -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat Progres Detail →"
                    android:textStyle="bold"
                    android:textColor="@color/sky_blue"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="22dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>