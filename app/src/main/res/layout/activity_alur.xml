<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/soft_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- CARD UTAMA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alur Belajar untuk Kamu"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins"
                android:textColor="@color/dark_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Berikut rekomendasi alur belajar yang disesuaikan dengan progress kamu."
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:textColor="@color/dark_text"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <!-- STEP 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Nomor -->
                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="@drawable/circle_green">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

                <!-- Garis -->
                <LinearLayout
                    android:layout_width="2dp"
                    android:layout_height="70dp"
                    android:background="@color/sky_blue"
                    android:layout_marginStart="-19dp"
                    android:layout_marginTop="36dp"/>

                <!-- Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_step_done"
                    android:padding="14dp"
                    android:layout_marginStart="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pelajari Dasar"
                            android:textStyle="bold"
                            android:textColor="@color/dark_text"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selesaikan materi dasar algoritma"
                            android:textSize="12sp"
                            android:textColor="@color/dark_text"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/checkbox_on_background"/>
                </LinearLayout>

            </LinearLayout>

            <!-- STEP 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="@drawable/circle_green">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="2dp"
                    android:layout_height="70dp"
                    android:background="@color/sky_blue"
                    android:layout_marginStart="-19dp"
                    android:layout_marginTop="36dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_step_done"
                    android:padding="14dp"
                    android:layout_marginStart="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kerjakan Latihan"
                            android:textStyle="bold"
                            android:textColor="@color/dark_text"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Latihan soal untuk memahami konsep"
                            android:textSize="12sp"
                            android:textColor="@color/dark_text"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/checkbox_on_background"/>
                </LinearLayout>

            </LinearLayout>

            <!-- STEP 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="@drawable/circle_blue">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_bg"
                    android:padding="14dp"
                    android:layout_marginStart="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Review Materi"
                            android:textStyle="bold"
                            android:textColor="@color/dark_text"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ulang kembali materi yang sulit"
                            android:textSize="12sp"
                            android:textColor="@color/dark_text"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- STEP 4 -->
            <include layout="@layout/item_step_chatbot"/>

            <!-- STEP 5 -->
            <include layout="@layout/item_step_progress"/>

            <!-- PROGRESS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_step_done"
                android:padding="16dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress Alur Belajar"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 dari 5 langkah selesai"
                    android:textSize="12sp"
                    android:textColor="@color/dark_text"
                    android:layout_marginTop="6dp"/>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="40"
                    android:max="100"
                    android:progressTint="@color/sky_blue"
                    android:progressBackgroundTint="@color/soft_white"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="40%"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text"
                    android:layout_gravity="end"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>