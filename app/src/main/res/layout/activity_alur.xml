<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_gradient">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/kontainer"
            android:padding="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/back"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alur Belajar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/dark_text"
                android:fontFamily="@font/poppins"
                android:layout_centerInParent="true"/>

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/alur"/>

        </RelativeLayout>


        <!-- CARD TOPIK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/card_bg">

            <TextView
                android:id="@+id/tvFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Topik yang Perlu Ditingkatkan"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/dark_text"
                android:fontFamily="@font/poppins"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Berdasarkan hasil quiz terakhir"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp"/>

            <!-- Topik 1 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Fotosintesis (Perlu latihan)"
                android:textSize="15sp"
                android:textColor="@color/dark_text"
                android:layout_marginTop="16dp"/>

            <!-- Topik 2 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Sistem Pernapasan"
                android:textSize="15sp"
                android:textColor="@color/dark_text"
                android:layout_marginTop="8dp"/>

            <!-- Topik 3 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Struktur Sel"
                android:textSize="15sp"
                android:textColor="@color/dark_text"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvMulaiLatihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mulai Latihan Lagi →"
                android:textStyle="bold"
                android:textColor="@color/sky_blue"
                android:fontFamily="@font/poppins"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"/>

        </LinearLayout>


        <!-- LANGKAH BELAJAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Langkah Selanjutnya"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/dark_text"
                android:fontFamily="@font/poppins"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Pelajari kembali ringkasan materi"
                android:textSize="15sp"
                android:textColor="@color/dark_text"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Diskusi dengan AI Chatbot"
                android:textSize="15sp"
                android:textColor="@color/dark_text"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Kerjakan quiz kembali"
                android:textSize="15sp"
                android:textColor="@color/dark_text"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/tvRekomendasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lihat Rekomendasi Detail →"
                android:textStyle="bold"
                android:textColor="@color/sky_blue"
                android:fontFamily="@font/poppins"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"/>
            <Button
                android:id="@+id/btnBukaQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mulai Quiz"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/sky_blue"
                android:textColor="@android:color/white"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>