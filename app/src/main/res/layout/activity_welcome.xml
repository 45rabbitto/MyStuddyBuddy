<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/soft_white">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/welcome"
        android:layout_marginTop="-90dp"/>

    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo_msbuddy"
        android:layout_marginTop="-75dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar "
            android:textSize="18sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/purple_200"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="lebih "
            android:textSize="18sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/primary_button"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cepat "
            android:textSize="18sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/purple_200"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dengan "
            android:textSize="18sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/primary_button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="bantuan "
            android:textSize="18sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/purple_200" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI "
            android:textSize="18sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/primary_button" />

    </LinearLayout>

    <Button
        android:id="@+id/btnMulai"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:text="Mulai"
        android:textColor="#ffffff"
        android:textSize="18sp"
        android:fontFamily="@font/poppins"
        android:textAllCaps="false"
        android:background="@drawable/button1"
        android:layout_marginTop="30dp" />

    <Button
        android:id="@+id/btnMulai"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:text="Mulai sebagai tamu"
        android:textSize="18sp"
        android:fontFamily="@font/poppins"
        android:textColor="@color/primary_button"
        android:textAllCaps="false"
        android:background="@drawable/button_line"
        android:layout_marginTop="15dp" />

</LinearLayout>