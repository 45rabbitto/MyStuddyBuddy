<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ================= CONTENT ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- ================= HALO ================= -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Halo!!!"
                android:textStyle="bold"
                android:textSize="30sp"
                android:fontFamily="@font/poppins"
                android:textColor="@color/dark_text" />

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginTop="-5dp"
                android:src="@drawable/halo" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Semangat belajar hari ini!!!"
            android:textSize="16sp"
            android:layout_marginStart="7dp"
            android:layout_marginTop="-10dp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/dark_text" />

        <!-- ================= CARD DASHBOARD ================= -->
        <RelativeLayout
            android:layout_width="360dp"
            android:layout_height="250dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:background="@drawable/kontainer"
            android:padding="20dp">

            <!-- STREAK -->
            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:background="@drawable/button_line"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="6dp">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/api" />

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="18sp"
                    android:textColor="@color/dark_text"
                    android:fontFamily="@font/poppins" />
            </LinearLayout>

            <!-- IMAGE -->
            <ImageView
                android:layout_width="280dp"
                android:layout_height="190dp"
                android:layout_centerInParent="true"
                android:layout_marginTop="20dp"
                android:scaleType="fitCenter"
                android:src="@drawable/dashboard" />

        </RelativeLayout>

        <!-- ================= MENU ================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="Menu"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/dark_text" />

        <!-- MENU ICON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- HISTORY -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/history"
                    android:layout_width="75dp"
                    android:layout_height="75dp"
                    android:background="@drawable/button_line"
                    android:padding="14dp"
                    android:src="@drawable/history"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="History"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins" />

            </LinearLayout>

            <!-- ALUR -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/alur"
                    android:layout_width="75dp"
                    android:layout_height="75dp"
                    android:background="@drawable/button_line"
                    android:padding="14dp"
                    android:src="@drawable/alur"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Alur"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins" />

            </LinearLayout>

            <!-- PROGRESS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/progres"
                    android:layout_width="75dp"
                    android:layout_height="75dp"
                    android:background="@drawable/button_line"
                    android:padding="14dp"
                    android:src="@drawable/progres"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Progress"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- navigasi -->
    <FrameLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_alignParentBottom="true"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- BOTTOM NAVBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/kontainer"
            android:elevation="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- HOME -->
            <LinearLayout
                android:id="@+id/layouthome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/home"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/home"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- SPACE -->
            <Space
                android:layout_width="130dp"
                android:layout_height="wrap_content" />

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/layoutprofile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/profile"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/profil"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- BUTTON UPLOAD FLOATING -->
        <FrameLayout
            android:layout_width="150dp"
            android:layout_height="130dp"
            android:layout_gravity="top|center_horizontal"
            android:translationY="-10dp"
            android:elevation="20dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- BG PALING BAWAH -->
            <ImageView
                android:id="@+id/bgUploadBawah"
                android:layout_width="130dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:layout_margin="10dp"
                android:scaleType="fitXY"
                android:src="@drawable/bg_upload_bawah" />

            <!-- ICON UPLOAD -->
            <ImageView
                android:id="@+id/upload"
                android:layout_width="200dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:elevation="25dp"
                android:focusable="true"
                android:scaleType="fitCenter"
                android:src="@drawable/upload" />

        </FrameLayout>

    </FrameLayout>

</RelativeLayout>