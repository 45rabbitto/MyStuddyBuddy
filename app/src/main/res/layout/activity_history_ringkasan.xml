<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_gradient">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/kontainer"
            android:padding="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:src="@drawable/back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History Ringasan"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/dark_text"
                android:fontFamily="@font/poppins"
                android:layout_centerInParent="true" />

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/history" />

        </RelativeLayout>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--------------"
            android:textSize="14sp"
            android:textColor="#777777"
            android:fontFamily="@font/poppins"
            android:layout_marginBottom="18dp"/>

        <!-- CARD RINGKASAN -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:cardCornerRadius="18dp"
            android:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Judul Materi"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/dark_text"
                    android:fontFamily="@font/poppins"/>

                <!-- INFO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dibuat pada xx/xx/xxxx"
                    android:textSize="12sp"
                    android:textColor="#8A8A8A"
                    android:layout_marginTop="4dp"/>

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"/>

                <!-- HASIL RINGKASAN -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="hasil ringkasan"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/dark_text"/>

                <!-- ACTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat Ringkasan Lengkap →"
                    android:textStyle="bold"
                    android:textColor="@color/sky_blue"
                    android:layout_marginTop="18dp"
                    android:layout_gravity="end"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- TITLE HISTORY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Riwayat Quiz"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/dark_text"
            android:fontFamily="@font/poppins"
            android:layout_marginBottom="14dp"/>

        <!-- QUIZ ITEM 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:cardCornerRadius="16dp"
            android:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- ICON -->
                <LinearLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/bg_quiz_icon">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="@color/sky_blue"/>
                </LinearLayout>

                <!-- INFO -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <!-- DATE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="xx/xx/xxxx"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/dark_text"/>

                    <!-- PERCENTAGE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="xx"
                        android:textSize="13sp"
                        android:textColor="#34A853"
                        android:layout_marginTop="3dp"/>

                    <!-- STATUS -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="xxx"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#34A853"
                        android:background="@drawable/circle_blue"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- ACTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail"
                    android:textStyle="bold"
                    android:textColor="@color/sky_blue"
                    android:textSize="13sp"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- QUIZ ITEM 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:cardCornerRadius="16dp"
            android:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- ICON -->
                <LinearLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/bg_quiz_icon">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="@color/sky_blue"/>
                </LinearLayout>

                <!-- INFO -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="xx/xx/xxxx"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/dark_text"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="xx"
                        android:textSize="13sp"
                        android:textColor="#D93025"
                        android:layout_marginTop="3dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="xxx"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#D93025"
                        android:background="@drawable/bg_badge_red"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- ACTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ulangi"
                    android:textStyle="bold"
                    android:textColor="@color/sky_blue"
                    android:textSize="13sp"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>