<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- AI Message -->
    <TextView
        android:id="@+id/tvAiMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginTop="5dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="50dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/button_line"
        android:fontFamily="@font/poppins"
        android:padding="14dp"
        android:text="Pesan AI"
        android:textColor="@color/primary_button" />

    <!-- Chat Container untuk pesan AI -->
    <LinearLayout
        android:id="@+id/chatContainerAI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp" />

    <!-- ScrollView untuk chat history -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada percakapan"
                android:textColor="@color/gray_text"
                android:fontFamily="@font/poppins"
                android:layout_gravity="center" />

        </LinearLayout>

    </ScrollView>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@drawable/button_line"
        android:gravity="center_vertical"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:hint="Ketik pesan..."
            android:paddingStart="16dp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/dark_text"
            android:textColorHint="@color/gray_text"
            android:background="@drawable/input_bg"/>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="35dp"
            android:layout_height="40dp"
            android:layout_marginRight="10dp"
            android:background="@drawable/card_bg"
            android:src="@drawable/kirim"
            android:scaleType="centerInside"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>