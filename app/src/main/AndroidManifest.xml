<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Storage permission (Android 13+ & below compatibility) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>

    <application
        android:name=".MyStudyBuddyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyStudyBuddy">

        <!-- =========================
             MAIN / DASHBOARD (LAUNCHER)
        ========================== -->
        <activity
            android:name="com.studdy.mystuddybuddy.presentation.screens.home.DashboardActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- =========================
             AUTH
        ========================== -->
        <activity android:name=".presentation.screens.auth.activity.WelcomeActivity"
            android:exported="false"/>

        <activity android:name=".presentation.screens.auth.activity.LoginActivity"
            android:exported="false"/>

        <activity android:name=".presentation.screens.auth.activity.RegisterActivity"
            android:exported="false"/>

        <!-- =========================
             MAIN FEATURES
        ========================== -->
        <activity android:name=".presentation.main.MainActivity"
            android:exported="false"/>

        <activity android:name=".presentation.screens.upload.activity.UploadActivity"
            android:exported="false"/>

        <activity android:name=".presentation.screens.profile.ProfileActivity"
            android:exported="false"/>

        <activity android:name=".presentation.screens.progress.activity.ProgresActivity"
            android:exported="false"/>

        <activity android:name=".presentation.screens.chatbot.activity.ChatbotActivity"
            android:exported="false"/>

        <activity
            android:name=".presentation.screens.quiz.activity.QuizActivity"
            android:exported="false"/>

        <activity
            android:name=".presentation.screens.quiz.activity.HasilKuisActivity"
            android:exported="false"/>

        <activity
            android:name=".presentation.screens.ringkasan.RingkasanActivity"
            android:exported="false"/>

        <!-- =========================
             HISTORY
        ========================== -->
        <activity android:name=".presentation.history.activity.FileHistoryActivity"
            android:exported="false"/>

        <activity android:name=".presentation.history.activity.QuizHistoryActivity"
            android:exported="false"/>

        <activity android:name="com.studdy.mystuddybuddy.presentation.history.activity.SummaryHistoryActivity"
            android:exported="false"/>

    </application>

</manifest>